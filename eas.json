{
  "cli": {
    "appVersionSource": "remote"
  },
  "build": {
    "local": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "local",
      "env": {
        "APP_STAGE": "local"
      }
    },
    "dev": {
      "environment": "development",
      "distribution": "internal",
      "channel": "dev",
      "env": {
        "APP_STAGE": "dev"
      }
    },
    "stg": {
      "environment": "preview",
      "distribution": "internal",
      "channel": "stg",
      "env": {
        "APP_STAGE": "stg"
      }
    },
    "prd": {
      "environment": "production",
      "distribution": "store",
      "channel": "prd",
      "autoIncrement": true,
      "env": {
        "APP_STAGE": "prd"
      }
    }
  },
  "submit": {
    "prd": {
      "android": {
        "track": "internal",
        "releaseStatus": "completed",
        "changesNotSentForReview": false
      },
      "ios": {
        "ascAppId": "6762027209",
        "metadataPath": "./store.config.json"
      }
    }
  }
}
