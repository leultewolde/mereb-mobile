{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@mobile/*": ["./*"]
    },
    "types": ["expo-router", "node"]
  },
  "include": ["app", "config", "providers", "hooks", "types", "e2e", "App.d.ts"],
  "exclude": ["node_modules", "babel.config.js", "config/**/*.test.ts"]
}
