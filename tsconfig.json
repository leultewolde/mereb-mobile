{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@mereb/app-feed/native": ["../../packages/app-feed/dist/index.d.ts"],
      "@mereb/app-messaging/native": ["../../packages/app-messaging/dist/native.d.ts"],
      "@mereb/app-profile/native": ["../../packages/app-profile/dist/index.d.ts"],
      "@mereb/tokens/native": ["../../packages/tokens/src/native.d.ts"],
      "@ui-native/*": ["../../packages/ui-native/src/*"],
      "@mobile/*": ["./*"]
    },
    "types": ["expo-router", "node"]
  },
  "include": ["app", "config", "providers", "hooks", "types", "e2e", "App.d.ts"],
  "exclude": ["node_modules", "babel.config.js", "config/**/*.test.ts"]
}
